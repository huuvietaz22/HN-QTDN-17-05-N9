<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Form View -->
        <record id="view_cong_viec_form" model="ir.ui.view">
            <field name="name">cong_viec.form</field>
            <field name="model">cong_viec</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <div class="oe_title">
                            <label for="ten_cong_viec"/>
                            <h1>
                                <field name="ten_cong_viec" placeholder="Tên công việc"/>
                            </h1>
                            <h2>
                                <field name="ma_cong_viec" readonly="1"/>
                            </h2>
                        </div>
                        <group col="2">
                            <group string="Thông tin công việc">
                                <field name="nguoi_phu_trach_id" options="{'no_create': True}"/>
                                <field name="ngay_bat_dau"/>
                                <field name="ngay_ket_thuc"/>
                            </group>
                            <group string="Ưu tiên và trạng thái">
                                <field name="muc_do_uu_tien" widget="badge"
                                       decoration-muted="muc_do_uu_tien == 'thap'"
                                       decoration-info="muc_do_uu_tien == 'trung_binh'"
                                       decoration-warning="muc_do_uu_tien == 'cao'"
                                       decoration-danger="muc_do_uu_tien == 'khan_cap'"/>
                                <field name="trang_thai" widget="badge"
                                       decoration-muted="trang_thai == 'moi'"
                                       decoration-warning="trang_thai == 'dang_thuc_hien'"
                                       decoration-success="trang_thai == 'hoan_thanh'"
                                       decoration-info="trang_thai == 'tam_dung'"/>
                                <field name="ti_le_hoan_thanh" widget="progressbar"/>
                                <field name="tong_nhiem_vu" readonly="1"/>
                                <field name="nhiem_vu_hoan_thanh" readonly="1"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Tổng quan">
                                <group col="2">
                                    <group string="Nhân sự">
                                        <field name="nguoi_phu_trach_id" options="{'no_create': True}"/>
                                        <field name="nhan_vien_phan_cong_ids" widget="many2many_tags" options="{'no_create': True, 'no_open': False}"/>
                                    </group>
                                    <group string="Thời gian &amp; effort">
                                        <field name="ngay_bat_dau"/>
                                        <field name="ngay_ket_thuc"/>
                                        <field name="gio_lam_du_kien"/>
                                        <field name="gio_lam_thuc_te"/>
                                    </group>
                                </group>
                                <group string="Mô tả">
                                    <field name="mo_ta" nolabel="1" placeholder="Mô tả mục tiêu, phạm vi và ghi chú triển khai công việc..."/>
                                </group>
                            </page>
                            <page string="Nhiệm vụ">
                                <field name="nhiem_vu_ids" context="{'default_cong_viec_id': active_id}">
                                    <tree editable="bottom">
                                        <field name="ma_nhiem_vu" readonly="1"/>
                                        <field name="ten_nhiem_vu"/>
                                        <field name="nguoi_thuc_hien_id" options="{'no_create': True}"/>
                                        <field name="ngay_bat_dau"/>
                                        <field name="ngay_ket_thuc"/>
                                        <field name="ti_le_hoan_thanh" widget="progressbar"/>
                                        <field name="trang_thai" readonly="1" widget="badge"
                                               decoration-muted="trang_thai == 'moi'"
                                               decoration-warning="trang_thai == 'dang_thuc_hien'"
                                               decoration-success="trang_thai == 'hoan_thanh'"
                                               decoration-info="trang_thai == 'tam_dung'"/>
                                    </tree>
                                </field>
                            </page>
                            <page string="Nhân viên thực hiện">
                                <field name="nhan_vien_phan_cong_ids" widget="many2many_tags" options="{'no_create': True}"/>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Tree View -->
        <record id="view_cong_viec_tree" model="ir.ui.view">
            <field name="name">cong_viec.tree</field>
            <field name="model">cong_viec</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="ma_cong_viec"/>
                    <field name="ten_cong_viec"/>
                    <field name="nguoi_phu_trach_id"/>
                    <field name="nhan_vien_phan_cong_ids" widget="many2many_tags" optional="hide"/>
                    <field name="trang_thai" widget="badge"
                           decoration-muted="trang_thai == 'moi'"
                           decoration-warning="trang_thai == 'dang_thuc_hien'"
                           decoration-success="trang_thai == 'hoan_thanh'"
                           decoration-info="trang_thai == 'tam_dung'"/>
                    <field name="muc_do_uu_tien" widget="badge"
                           decoration-muted="muc_do_uu_tien == 'thap'"
                           decoration-info="muc_do_uu_tien == 'trung_binh'"
                           decoration-warning="muc_do_uu_tien == 'cao'"
                           decoration-danger="muc_do_uu_tien == 'khan_cap'"/>
                    <field name="ti_le_hoan_thanh" widget="progressbar"/>
                    <field name="tong_nhiem_vu"/>
                    <field name="ngay_bat_dau"/>
                    <field name="ngay_ket_thuc"/>
                </tree>
            </field>
        </record>

        <!-- Kanban View -->
        <record id="view_cong_viec_kanban" model="ir.ui.view">
            <field name="name">cong_viec.kanban</field>
            <field name="model">cong_viec</field>
            <field name="arch" type="xml">
                <kanban class="o_kanban_mobile" default_group_by="trang_thai">
                    <field name="ma_cong_viec"/>
                    <field name="ten_cong_viec"/>
                    <field name="nguoi_phu_trach_id"/>
                    <field name="nhan_vien_phan_cong_ids"/>
                    <field name="muc_do_uu_tien"/>
                    <field name="trang_thai"/>
                    <field name="ti_le_hoan_thanh"/>
                    <field name="ngay_bat_dau"/>
                    <field name="ngay_ket_thuc"/>
                    <field name="tong_nhiem_vu"/>
                    <field name="nhiem_vu_hoan_thanh"/>
                    <templates>
                        <t t-name="kanban-box">
                            <div t-attf-class="oe_kanban_global_click o_kanban_record #{record.muc_do_uu_tien.raw_value == 'khan_cap' ? 'border-danger' : record.muc_do_uu_tien.raw_value == 'cao' ? 'border-warning' : record.muc_do_uu_tien.raw_value == 'trung_binh' ? 'border-info' : 'border-secondary'}" style="border-left-width: 4px;">
                                <div class="o_kanban_record_top mb8">
                                    <div class="o_kanban_record_headings">
                                        <strong class="o_kanban_record_title">
                                            <field name="ten_cong_viec"/>
                                        </strong>
                                        <div class="text-muted">
                                            <field name="ma_cong_viec"/>
                                        </div>
                                    </div>
                                    <img t-if="record.nguoi_phu_trach_id.raw_value"
                                         t-att-src="kanban_image('nhan_vien', 'image', record.nguoi_phu_trach_id.raw_value)"
                                         t-att-title="record.nguoi_phu_trach_id.value"
                                         class="oe_kanban_avatar rounded-circle"
                                         alt="Người phụ trách"/>
                                </div>
                                <div class="o_kanban_record_body">
                                    <div class="mb8">
                                        <field name="trang_thai" widget="badge"
                                               decoration-muted="trang_thai == 'moi'"
                                               decoration-warning="trang_thai == 'dang_thuc_hien'"
                                               decoration-success="trang_thai == 'hoan_thanh'"
                                               decoration-info="trang_thai == 'tam_dung'"/>
                                        <field name="muc_do_uu_tien" widget="badge"
                                               decoration-muted="muc_do_uu_tien == 'thap'"
                                               decoration-info="muc_do_uu_tien == 'trung_binh'"
                                               decoration-warning="muc_do_uu_tien == 'cao'"
                                               decoration-danger="muc_do_uu_tien == 'khan_cap'"/>
                                    </div>
                                    <div class="text-muted mb4">
                                        <i class="fa fa-user-o" title="Người phụ trách"/>
                                        <span> </span>
                                        <field name="nguoi_phu_trach_id"/>
                                    </div>
                                    <div class="mb8">
                                        <field name="nhan_vien_phan_cong_ids" widget="many2many_tags"/>
                                    </div>
                                    <div class="d-flex justify-content-between text-muted mb4">
                                        <span>
                                            <i class="fa fa-tasks" title="Nhiệm vụ"/>
                                            <field name="nhiem_vu_hoan_thanh"/>/<field name="tong_nhiem_vu"/>
                                        </span>
                                        <span>
                                            <field name="ti_le_hoan_thanh"/>%
                                        </span>
                                    </div>
                                    <field name="ti_le_hoan_thanh" widget="progressbar"/>
                                </div>
                                <div class="o_kanban_record_bottom mt8">
                                    <div class="oe_kanban_bottom_left text-muted">
                                        <i class="fa fa-calendar-o" title="Thời hạn"/>
                                        <span> </span>
                                        <field name="ngay_bat_dau"/>
                                        <span t-if="record.ngay_ket_thuc.raw_value"> - </span>
                                        <field name="ngay_ket_thuc"/>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <!-- Search View -->
        <record id="view_cong_viec_search" model="ir.ui.view">
            <field name="name">cong_viec.search</field>
            <field name="model">cong_viec</field>
            <field name="arch" type="xml">
                <search>
                    <field name="ma_cong_viec"/>
                    <field name="ten_cong_viec"/>
                    <field name="nguoi_phu_trach_id"/>
                    <field name="nhan_vien_phan_cong_ids"/>
                    <field name="muc_do_uu_tien"/>
                    <field name="trang_thai"/>
                    <filter string="Ưu tiên cao" name="uu_tien_cao" domain="[('muc_do_uu_tien', 'in', ['cao', 'khan_cap'])]"/>
                    <filter string="Đang thực hiện" name="dang_thuc_hien" domain="[('trang_thai', '=', 'dang_thuc_hien')]"/>
                    <filter string="Quá hạn" name="qua_han" domain="[('ngay_ket_thuc', '&lt;', context_today()), ('trang_thai', '!=', 'hoan_thanh')]"/>
                    <group expand="0" string="Nhóm theo">
                        <filter string="Trạng thái" name="group_trang_thai" context="{'group_by': 'trang_thai'}"/>
                        <filter string="Ưu tiên" name="group_muc_do_uu_tien" context="{'group_by': 'muc_do_uu_tien'}"/>
                        <filter string="Người phụ trách" name="group_nguoi_phu_trach" context="{'group_by': 'nguoi_phu_trach_id'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- Action -->
        <record id="action_cong_viec" model="ir.actions.act_window">
            <field name="name">Công việc</field>
            <field name="res_model">cong_viec</field>
            <field name="view_mode">kanban,tree,form</field>
            <field name="search_view_id" ref="view_cong_viec_search"/>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Tạo công việc mới
                </p>
            </field>
        </record>
    </data>
</odoo>
