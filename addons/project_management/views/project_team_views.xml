<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_project_team_role_tree" model="ir.ui.view">
            <field name="name">project.team.role.tree</field>
            <field name="model">project.team.role</field>
            <field name="arch" type="xml">
                <tree decoration-success="state == 'active'" decoration-muted="state == 'done'" decoration-info="state == 'planned'">
                    <field name="project_id"/>
                    <field name="employee_id"/>
                    <field name="role_code"/>
                    <field name="responsibility"/>
                    <field name="allocation_percent" widget="progressbar"/>
                    <field name="start_date"/>
                    <field name="end_date"/>
                    <field name="is_main_role"/>
                    <field name="state"/>
                </tree>
            </field>
        </record>

        <record id="view_project_team_role_form" model="ir.ui.view">
            <field name="name">project.team.role.form</field>
            <field name="model">project.team.role</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <div class="oe_title">
                            <label for="display_name"/>
                            <h1>
                                <field name="display_name" readonly="1"/>
                            </h1>
                        </div>
                        <group col="2">
                            <group string="Thông tin phân vai">
                                <field name="project_id"/>
                                <field name="employee_id"/>
                                <field name="role_code"/>
                                <field name="is_main_role"/>
                            </group>
                            <group string="Thời gian &amp; trạng thái">
                                <field name="allocation_percent"/>
                                <field name="start_date"/>
                                <field name="end_date"/>
                                <field name="state"/>
                            </group>
                        </group>
                        <group string="Trách nhiệm">
                            <field name="responsibility" nolabel="1" placeholder="Mô tả trách nhiệm cụ thể của nhân sự trong dự án..."/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_project_team_role_search" model="ir.ui.view">
            <field name="name">project.team.role.search</field>
            <field name="model">project.team.role</field>
            <field name="arch" type="xml">
                <search>
                    <field name="project_id"/>
                    <field name="employee_id"/>
                    <field name="role_code"/>
                    <field name="state"/>
                    <filter name="filter_active" string="Đang tham gia" domain="[('state', '=', 'active')]"/>
                    <filter name="filter_main_role" string="Vai trò chính" domain="[('is_main_role', '=', True)]"/>
                    <separator/>
                    <group expand="0" string="Nhóm theo">
                        <filter name="group_project" string="Dự án" context="{'group_by': 'project_id'}"/>
                        <filter name="group_employee" string="Nhân sự" context="{'group_by': 'employee_id'}"/>
                        <filter name="group_role" string="Vai trò" context="{'group_by': 'role_code'}"/>
                        <filter name="group_state" string="Trạng thái" context="{'group_by': 'state'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="action_project_team_role" model="ir.actions.act_window">
            <field name="name">Vai trò dự án</field>
            <field name="res_model">project.team.role</field>
            <field name="view_mode">tree,form</field>
            <field name="search_view_id" ref="view_project_team_role_search"/>
            <field name="context">{'search_default_group_project': 1}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Tạo phân công vai trò cho nhân sự trong dự án
                </p>
            </field>
        </record>
    </data>
</odoo>
