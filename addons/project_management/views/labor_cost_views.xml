<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_cong_viec_labor_cost_tree" model="ir.ui.view">
            <field name="name">cong_viec.labor.cost.tree</field>
            <field name="model">cong_viec</field>
            <field name="arch" type="xml">
                <tree string="Chi phí nhân sự">
                    <field name="du_an_id"/>
                    <field name="ma_cong_viec"/>
                    <field name="ten_cong_viec"/>
                    <field name="nguoi_phu_trach_id"/>
                    <field name="nhan_vien_phan_cong_ids" widget="many2many_tags"/>
                    <field name="gio_lam_du_kien"/>
                    <field name="gio_lam_thuc_te"/>
                    <field name="don_gia_gio_trung_binh"/>
                    <field name="chi_phi_nhan_su_du_kien"/>
                    <field name="chi_phi_nhan_su_thuc_te"/>
                    <field name="trang_thai"/>
                </tree>
            </field>
        </record>

        <record id="view_cong_viec_labor_cost_search" model="ir.ui.view">
            <field name="name">cong_viec.labor.cost.search</field>
            <field name="model">cong_viec</field>
            <field name="arch" type="xml">
                <search string="Chi phí nhân sự">
                    <field name="du_an_id"/>
                    <field name="ten_cong_viec"/>
                    <field name="nguoi_phu_trach_id"/>
                    <field name="nhan_vien_phan_cong_ids"/>
                    <filter name="has_labor_cost" string="Có chi phí nhân sự" domain="[('chi_phi_nhan_su_thuc_te', '>', 0)]"/>
                    <group expand="0" string="Nhóm theo">
                        <filter name="group_du_an" string="Dự án" context="{'group_by': 'du_an_id'}"/>
                        <filter name="group_nguoi_phu_trach" string="Người phụ trách" context="{'group_by': 'nguoi_phu_trach_id'}"/>
                        <filter name="group_trang_thai" string="Trạng thái" context="{'group_by': 'trang_thai'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="action_labor_costs" model="ir.actions.act_window">
            <field name="name">Chi phí nhân sự</field>
            <field name="res_model">cong_viec</field>
            <field name="view_mode">tree,form,graph</field>
            <field name="view_id" ref="view_cong_viec_labor_cost_tree"/>
            <field name="search_view_id" ref="view_cong_viec_labor_cost_search"/>
            <field name="context">{'search_default_group_du_an': 1}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Chưa có công việc nào để tính chi phí nhân sự.
                </p>
            </field>
        </record>
    </data>
</odoo>
